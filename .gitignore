# -------------------------------------------------------------------
# Local TTS AI runtime assets
# Model weights and local AI caches used by this project only.
# These are large and machine-specific, so they must not be committed.
# -------------------------------------------------------------------
.local-tts-ai/

# -------------------------------------------------------------------
# Python environments
# Ignore local virtual environments, including .venv, .venv-qwen, etc.
# -------------------------------------------------------------------
.venv*/
venv/
env/

# -------------------------------------------------------------------
# Python cache / tooling
# Generated by Python, test runners, type checkers, and linters.
# -------------------------------------------------------------------
__pycache__/
*.py[cod]

.pytest_cache/
.mypy_cache/
.pyright/
.ruff_cache/

.test-tmp/

# -------------------------------------------------------------------
# Audio API generated files
# Generated audio/output should not be committed.
# -------------------------------------------------------------------
audio-api/output/
output/

*.wav
*.mp3

# -------------------------------------------------------------------
# Local storage
# Keep storage/audio/.gitkeep and storage/lessons/.gitkeep, but ignore generated/private files.
# -------------------------------------------------------------------
/storage/*
!/storage/audio/
!/storage/lessons/

/storage/audio/*
!/storage/audio/.gitkeep

/storage/lessons/*
!/storage/lessons/.gitkeep

# -------------------------------------------------------------------
# Local databases / job state
# Useful if the API later stores jobs locally with SQLite.
# -------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -------------------------------------------------------------------
# Hugging Face / local model caches
# Only needed if you download models inside the repo.
# Normal Hugging Face cache outside the repo is unaffected.
# -------------------------------------------------------------------
.cache/
hf-cache/
models/

# -------------------------------------------------------------------
# Environment variables / secrets
# Never commit real local env files.
# Keep example env files trackable.
# -------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -------------------------------------------------------------------
# Node / package manager
# Dependencies and package-manager caches.
# -------------------------------------------------------------------
node_modules/
.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# -------------------------------------------------------------------
# Build outputs / monorepo tooling
# -------------------------------------------------------------------
dist/
build/
.turbo/

# -------------------------------------------------------------------
# TanStack Start / Vinxi / Nitro outputs
# -------------------------------------------------------------------
web/.tanstack/tmp/
web/.vinxi/
web/.nitro/
web/.output/
web/dist/

# -------------------------------------------------------------------
# OS / editor noise
# -------------------------------------------------------------------
.DS_Store
Thumbs.db
