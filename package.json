{
  "name": "audiofier-tts",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "workspaces": [
    "audio-api",
    "web"
  ],
  "scripts": {
    "dev": "turbo dev --env-mode=loose",
    "dev:audio": "turbo dev --filter=audiofier-audio-api --env-mode=loose",
    "dev:web": "turbo dev --filter=audiofier-web --env-mode=loose",
    "setup:audio": "npm run setup:venv -w audiofier-audio-api",
    "build": "turbo build",
    "format": "prettier --write . && npm run format -w audiofier-audio-api",
    "format:check": "prettier --check . && npm run format:check -w audiofier-audio-api",
    "lint": "eslint . && npm run lint -w audiofier-audio-api",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@rolldown/plugin-babel": "0.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript-eslint": "8.58.2"
  }
}
